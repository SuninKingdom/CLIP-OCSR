# CLIP-OCSR Model Paths
STAGE1_CKPT_PATH=/path/to/stage1_clip_checkpoint.pt
STAGE2_CKPT_PATH=/path/to/stage2_ocsr_checkpoint.pt
TOKENIZER_PATH=assets/tokenizer_smiles.json
ABBREV_GROUP_PATH=assets/abbrev_group.json

# Dataset Paths
MARKUSH_DATASET_DIR=/path/to/markush/images
MARKUSH_LABELS_PATH=/path/to/labels.json
MARKUSH_OUTPUT_DIR=./results

# LLM API (OpenAI-compatible, choose one provider)
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

MIMO_API_KEY=your_api_key_here
MIMO_BASE_URL=https://api.mimo.com/v1
MIMO_MODEL=mimo-v2.5

# MinerU Layout Analysis
MINERU_TOKEN=your_mineru_jwt_token_here
